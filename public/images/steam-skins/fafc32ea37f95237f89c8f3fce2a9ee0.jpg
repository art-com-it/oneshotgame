<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/images/favicon/favicon.svg" />
    <link rel="apple-touch-icon" href="/images/favicon/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AI Game Store</title>
    
    <!-- Preload critical resources -->
    <link rel="preload" href="/images/logo/logo.png" as="image" type="image/png">
    <link rel="preload" href="/vite.svg" as="image" type="image/svg+xml">
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;800&display=swap" as="style">
    
    <!-- Display font: Orbitron for a futuristic look -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;600;800&display=swap" rel="stylesheet">

    <!-- Global text fonts with Cyrillic support: Noto Sans + Roboto -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;600;700&family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <!-- Performance: preconnect/dns-prefetch to Steam CDNs used by product images -->
    <link rel="preconnect" href="https://cdn.cloudflare.steamstatic.com" crossorigin>
    <link rel="dns-prefetch" href="//cdn.cloudflare.steamstatic.com">
    <link rel="preconnect" href="https://shared.akamai.steamstatic.com" crossorigin>
    <link rel="dns-prefetch" href="//shared.akamai.steamstatic.com">
    <link rel="preconnect" href="https://steamcommunity.com" crossorigin>
    <link rel="dns-prefetch" href="//steamcommunity.com">
    <script type="module" crossorigin src="/assets/index-CgX2NKyZ.js"></script>
    <link rel="stylesheet" crossorigin href="/assets/index-BW7XrAaQ.css">
  </head>
  <body>
    <div id="app"></div>
  </body>
</html>

