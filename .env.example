# Копируйте в .env и заполните значения
PORT=3001
SITE_DOMAIN=oneshotgame.shop
NODE_ENV=production

# Steam
STEAM_API_KEY=
RETURN_URL=https://oneshotgame.shop/auth/steam/return

# Сессии (Redis опционально)
ENABLE_REDIS=0
REDIS_URL=
REDIS_HOST=redis
REDIS_PORT=6379

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Yandex Smartcaptcha (серверный ключ — задайте в .env, не храните в коде)
YANDEX_CAPTCHA_SECRET_KEY=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
SUPPORT_NOTIFY_EMAIL=

# CORS / Frontend
FRONTEND_URL=https://oneshotgame.shop
BASE_URL=https://oneshotgame.shop
