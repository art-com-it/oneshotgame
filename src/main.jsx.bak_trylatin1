function SkinRoulette() {
  const [isSpinning, setIsSpinning] = React.useState(false)
  const [result, setResult] = React.useState(null)
  const { formatPrice } = useLang()
  
  const skins = DATA.products.filter(p => p.category === 'skin').slice(0, 10)
  
  const spin = () => {
    if (isSpinning) return
    
    setIsSpinning(true)
    setResult(null)
    
    setTimeout(() => {
      const randomSkin = skins[Math.floor(Math.random() * skins.length)]
      setResult(randomSkin)
      setIsSpinning(false)
    }, 3000)
  }

  return (
    <div className="bg-gradient-to-br from-[#161f38] to-[#1f2a4a] rounded-lg p-6 border border-white/10">
      <div className="text-center space-y-6">
        <h2 className="text-2xl font-bold">СҖСҹРӢВ° Р В РЎС“Р В»Р ВөРЎвҖҡР С”Р В° РЎРғР С”Р С‘Р Р…Р С•Р РҶ</h2>
        
        <div className="relative h-32 bg-[#0D1A2F] rounded-lg overflow-hidden border border-white/20">
          <div className={`flex transition-transform duration-3000 ease-out ${isSpinning ? 'animate-spin-roulette' : ''}`}>
            {[...skins, ...skins, ...skins].map((skin, i) => (
              <div key={i} className="flex-shrink-0 w-24 h-32 p-2 border-r border-white/10">
                <LazyImage src={skin.image} alt={skin.name} className="w-full h-20 object-cover rounded" />
                <div className="text-xs mt-1 truncate">{skin.name}</div>
              </div>
            ))}
          </div>
          <div className="absolute top-0 left-1/2 transform -translate-x-1/2 w-1 h-full bg-red-500 z-10"></div>
        </div>

        {result && (
          <div className="bg-[#0D1A2F] rounded-lg p-4 border border-green-500/50">
            <h3 className="text-lg font-bold text-green-400">Р СҹР С•Р В·Р Т‘РЎРӮР В°Р РҶР В»РЎРҸР ВөР Сҳ!</h3>
            <div className="flex items-center justify-center gap-4 mt-2">
              <LazyImage src={result.image} alt={result.name} className="w-16 h-16 object-cover rounded" />
              <div>
                <div className="font-medium">{result.name}</div>
                <div className="text-blue-400">{formatPrice(result.price)}</div>
              </div>
            </div>
          </div>
        )}

        <button 
          onClick={spin}
          disabled={isSpinning}
          className={`px-8 py-3 rounded-lg font-medium transition-all transform hover:scale-105 ${
            isSpinning 
              ? 'bg-gray-600 cursor-not-allowed' 
              : 'bg-gradient-to-r from-purple-600 to-pink-600 hover:from-purple-700 hover:to-pink-700'
          }`}
        >
          {isSpinning ? 'Р СҷРЎРӮРЎС“РЎвҖҡР С‘РЎвҖҡРЎРғРЎРҸ...' : 'Р СҷРЎРӮРЎС“РЎвҖҡР С‘РЎвҖҡРЎРҠ РЎРӮРЎС“Р В»Р ВөРЎвҖҡР С”РЎС“ (100РІвҖҡР…)'}
        </button>
      </div>
    </div>
  )
}

