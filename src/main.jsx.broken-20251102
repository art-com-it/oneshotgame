// Cart context
const CartContext = React.createContext(null)

// Удалён CRM/CMS: провайдер и контексты больше не используются

function CartProvider({ children }) {
  const [items, setItems] = React.useState(() => {
    try {
      const saved = localStorage.getItem('cart-items')
      return saved ? JSON.parse(saved) : []
    } catch {
      return []
    }
  })
  React.useEffect(() => {
    localStorage.setItem('cart-items', JSON.stringify(items))
  }, [items])
  const addItem = (product, qty = 1) => {
    // Проверяем авторизацию через cookie и localStorage
    const hasCookie = document.cookie.includes('profile_auth=1')
    const hasLocalStorage = localStorage.getItem('profile-auth') === '1'
    const authorized = hasCookie || hasLocalStorage
    
    if (!authorized) {
      window.dispatchEvent(new Event('open-login'))
      return
    }
    setItems(prev => {
      const exists = prev.find(i => i.id === product.id)
      if (exists) {
        return prev.map(i => i.id === product.id ? { ...i, qty: i.qty + qty } : i)
      }
      return [...prev, { ...product, image: product.image || '', qty }]
    })
  }
  const removeItem = (id) => setItems(prev => prev.filter(i => i.id !== id))
  const updateQty = (id, qty) => setItems(prev => prev.map(i => i.id === id ? { ...i, qty: Math.max(1, qty) } : i))
  const clear = () => setItems([])
  const totalQuantity = items.reduce((sum, i) => sum + i.qty, 0)
  const totalPrice = items.reduce((sum, i) => sum + i.price * i.qty, 0)
  const value = { items, addItem, removeItem, updateQty, clear, totalQuantity, totalPrice }
  return <CartContext.Provider value={value}>{children}</CartContext.Provider>
}
function useCart() { const ctx = React.useContext(CartContext); if (!ctx) throw new Error('useCart must be used within CartProvider'); return ctx }
function CartBadge() {
  const { totalQuantity } = useCart()
  const isAuthorized = localStorage.getItem('profile-auth') === '1'
  if (!isAuthorized || totalQuantity <= 0) return null
  return (
    <span className="absolute -top-1 -right-2 min-w-[18px] h-5 px-1 rounded-full bg-[#7e2aa8] text-xs flex items-center justify-center">
      {totalQuantity}
    </span>
  )
}

// Языковой контекст: переключение языка и валюты, форматирование цен
const LangContext = React.createContext(null)
function LangProvider({ children }) {
  const [lang, setLang] = React.useState(() => localStorage.getItem('lang') || 'ru')
  React.useEffect(() => { localStorage.setItem('lang', lang) }, [lang])
  const RATE = 90
  const currency = lang === 'ru' ? 'RUB' : 'USD'
  const formatPrice = (amountUsd) => {
    try {
      if (lang === 'ru') return new Intl.NumberFormat('ru-RU', { style: 'currency', currency: 'RUB' }).format(amountUsd * RATE)
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(amountUsd)
    } catch {
      return lang === 'ru' ? `${Math.round(amountUsd * RATE)} ₽` : `$${amountUsd.toFixed(2)}`
    }
  }
  const toAmountInCurrency = (amountUsd) => lang === 'ru' ? amountUsd * RATE : amountUsd
  const DICT = {
    ru: { 'skins.title': 'Скины CS2' },
    en: { 'skins.title': 'CS2 Skins' }
  }
  const t = (key) => (DICT[lang] && DICT[lang][key]) || key
  const value = { lang, setLang, currency, rate: RATE, formatPrice, toAmountInCurrency, t }
  return <LangContext.Provider value={value}>{children}</LangContext.Provider>
}

function useLang() { 
  const ctx = React.useContext(LangContext); 
  if (!ctx) throw new Error('useLang must be used within LangProvider'); 
  return ctx; 
}

