                >
                  <option value="Consumer Grade">Consumer Grade</option>
                  <option value="Industrial Grade">Industrial Grade</option>
                  <option value="Mil-Spec">Mil-Spec</option>
                  <option value="Restricted">Restricted</option>
                  <option value="Classified">Classified</option>
                  <option value="Covert">Covert</option>
                  <option value="★ Covert">★ Covert</option>
                </select>
                <select
                  value={newSkin.condition}
                  onChange={(e) => setNewSkin(prev => ({ ...prev, condition: e.target.value }))}
                  className="px-3 py-2 rounded bg-[#161f38] border border-white/10"
                >
                  <option value="Factory New">Factory New</option>
                  <option value="Minimal Wear">Minimal Wear</option>
                  <option value="Field-Tested">Field-Tested</option>
                  <option value="Well-Worn">Well-Worn</option>
                  <option value="Battle-Scarred">Battle-Scarred</option>
                </select>
                <input
                  type="number"
                  step="0.01"
                  placeholder="Цена ($)"
                  value={newSkin.price}
                  onChange={(e) => setNewSkin(prev => ({ ...prev, price: e.target.value }))}
                  className="px-3 py-2 rounded bg-[#161f38] border border-white/10"
                />
                <input
                  type="url"
                  placeholder="Ссылка на изображение"
                  value={newSkin.image}
                  onChange={(e) => setNewSkin(prev => ({ ...prev, image: e.target.value }))}
                  className="px-3 py-2 rounded bg-[#161f38] border border-white/10"
                />
              </div>
              <div className="flex gap-2">
                <button 
                  onClick={sellSkin}
                  className="px-4 py-2 rounded bg-green-600 hover:bg-green-700"
                >
                  Выставить на продажу
                </button>
                <button 
                  onClick={() => setShowSellForm(false)}
                  className="px-4 py-2 rounded bg-[#161f38] hover:bg-[#2a3f5f]"
                >
                  Отменить
                </button>
              </div>
            </div>
          )}
          
          <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {sellingSkins.map(skin => (
              <div key={skin.id} className="p-4 rounded-lg border border-white/10 bg-[#0D1A2F] space-y-3">
                <div className="aspect-video bg-[#161f38] rounded-lg flex items-center justify-center">
                  {skin.image ? (
                    <LazyImage src={skin.image} alt={skin.name} className="w-full h-full object-cover rounded-lg" />
                  ) : (
                    <div className="text-white/50">Нет изображения</div>
                  )}
                </div>
                <div>
                  <h4 className="font-semibold">{skin.name}</h4>
                  <div className="text-sm text-white/70 space-y-1">
                    <div>Игра: {skin.game}</div>
                    <div>Состояние: {skin.condition}</div>
                    <div style={{ color: rarityColors[skin.rarity] }}>
                      Редкость: {skin.rarity}
                    </div>
                    <div>Продавец: {skin.seller}</div>
                  </div>
                </div>
                <div className="flex items-center justify-between">
                  <span className="text-xl font-bold text-green-400">${skin.price}</span>
                  {isAuthorized && skin.seller !== userName && (
                    <button 
                      onClick={() => buySkin(skin.id)}
                      className="px-3 py-1 rounded bg-[#7e2aa8] hover:bg-[#8e3bc5] text-sm"
                    >
                      Купить
                    </button>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
      
      {activeTab === 'inventory' && (
        <div className="space-y-4">
          <h3 className="text-xl font-semibold">Мой инвентарь</h3>
          {!isAuthorized ? (
            <p className="text-white/70">Войдите в систему, чтобы увидеть свой инвентарь.</p>
          ) : userSkins.length === 0 ? (
            <p className="text-white/70">Ваш инвентарь пуст. Купите скины на торговой площадке!</p>
          ) : (
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
              {userSkins.map(skin => (
                <div key={`${skin.id}-${skin.purchaseDate}`} className="p-4 rounded-lg border border-white/10 bg-[#0D1A2F] space-y-3">
                  <div className="aspect-video bg-[#161f38] rounded-lg flex items-center justify-center">
                    {skin.image ? (
                      <LazyImage src={skin.image} alt={skin.name} className="w-full h-full object-cover rounded-lg" />
                    ) : (
                      <div className="text-white/50">Нет изображения</div>
                    )}
                  </div>
                  <div>
                    <h4 className="font-semibold">{skin.name}</h4>
                    <div className="text-sm text-white/70 space-y-1">
                      <div>Игра: {skin.game}</div>
                      <div>Состояние: {skin.condition}</div>
                      <div style={{ color: rarityColors[skin.rarity] }}>
                        Редкость: {skin.rarity}
                      </div>
                      <div>Куплен: {skin.purchaseDate}</div>
                    </div>
                  </div>
                  <div className="text-lg font-bold text-blue-400">
                    Куплен за: ${skin.price}
                  </div>
                </div>
              ))}
            </div>
          )}
        </div>
      )}
    </section>
  )
}

