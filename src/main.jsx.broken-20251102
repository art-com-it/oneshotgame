          />
              <button aria-label="prev" onClick={() => go(-1)} className="absolute left-2 top-1/2 -translate-y-1/2 px-2 py-1 rounded bg-[#0D1A2F] border border-white/10">‹</button>
              <button aria-label="next" onClick={() => go(1)} className="absolute right-2 top-1/2 -translate-y-1/2 px-2 py-1 rounded bg-[#0D1A2F] border border-white/10">›</button>
              <div className="absolute bottom-2 left-0 right-0 flex justify-center gap-2">
                {images.map((_, i) => (
                  <button key={i} onClick={() => setIdx(i)} aria-label={`go-${i}`} className={`h-2 w-2 rounded-full ${i===idx?'bg-[#4A90E2]':'bg-white/30'}`}></button>
                ))}
