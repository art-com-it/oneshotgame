function Skins() {
  const { t, formatPrice } = useLang();
  const skins = DATA.products.filter(p => p.category === 'skin');
  const [query, setQuery] = React.useState('')
  const [typeFilter, setTypeFilter] = React.useState('all')
  const [minPrice, setMinPrice] = React.useState('')
  const [maxPrice, setMaxPrice] = React.useState('')
  const [sourceFilter, setSourceFilter] = React.useState('all') // all | steam_market | local
  const [hasRealPhoto, setHasRealPhoto] = React.useState(false)
  const [selectedTags, setSelectedTags] = React.useState([])
  const types = Array.from(new Set(skins.map(s => s.type))).filter(Boolean)
  const TAGS = ['StatTrak', 'Doppler', 'Fade', 'Tiger Tooth', 'Crimson Web', 'Case Hardened', 'Printstream', 'Dragon Lore', 'Asiimov']
  const hasTag = (p, tag) => {
    const name = String(p.cs2MarketName || p.name || '').toLowerCase()
    const t = tag.toLowerCase()
    return name.includes(t.replace(/\s+/g, ' '))
  }
  const hasHttpImage = (p) => {
    const img = String(p.image || '')
    if (img.startsWith('http://') || img.startsWith('https://')) return true
    if (Array.isArray(p.images)) {
      return p.images.some(u => typeof u === 'string' && (u.startsWith('http://') || u.startsWith('https://')))
    }
    return false
  }
  const q = query.trim().toLowerCase()
  const min = parseFloat(minPrice)
  const max = parseFloat(maxPrice)
  const filtered = skins.filter(p => {
    if (q && !String(p.name).toLowerCase().includes(q)) return false
    if (typeFilter !== 'all' && p.type !== typeFilter) return false
    if (sourceFilter === 'steam_market' && p.source !== 'steam_market') return false
    if (sourceFilter === 'local' && p.source === 'steam_market') return false
    if (!isNaN(min) && p.price < min) return false
    if (!isNaN(max) && p.price > max) return false
    if (hasRealPhoto && !hasHttpImage(p)) return false
    if (selectedTags.length > 0) {
      for (const tag of selectedTags) {
        if (!hasTag(p, tag)) return false
      }
    }
    return true
  })
  return (
    <div className="space-y-4">
      <h1 className="text-2xl font-bold">{t('skins.title') || 'Скины'}</h1>
      <div className="flex flex-wrap items-end gap-3 p-3 rounded-lg border border-white/10 bg-[#0D1A2F]">
        <div className="flex-1 min-w-[200px]">
          <label className="text-xs opacity-70">Поиск</label>
          <input value={query} onChange={e => setQuery(e.target.value)} placeholder="Название скина"
                 className="w-full px-3 py-2 rounded bg-[#161f38] border border-white/10" />
        </div>
        <div>
          <label className="text-xs opacity-70">Тип</label>
          <select value={typeFilter} onChange={e => setTypeFilter(e.target.value)}
                  className="w-[160px] px-3 py-2 rounded bg-[#161f38] border border-white/10">
            <option value="all">Все</option>
            {types.map(t => (<option key={t} value={t}>{t}</option>))}
          </select>
        </div>
        <div>
          <label className="text-xs opacity-70">Источник</label>
          <select value={sourceFilter} onChange={e => setSourceFilter(e.target.value)}
                  className="w-[160px] px-3 py-2 rounded bg-[#161f38] border border-white/10">
            <option value="all">Все</option>
            <option value="steam_market">Steam Market</option>
            <option value="local">Локальные</option>
          </select>
        </div>
        <div>
          <label className="text-xs opacity-70">Цена от</label>
          <input value={minPrice} onChange={e => setMinPrice(e.target.value)} type="number" min="0" step="0.01"
                 className="w-[120px] px-3 py-2 rounded bg-[#161f38] border border-white/10" />
        </div>
        <div>
          <label className="text-xs opacity-70">Цена до</label>
          <input value={maxPrice} onChange={e => setMaxPrice(e.target.value)} type="number" min="0" step="0.01"
                 className="w-[120px] px-3 py-2 rounded bg-[#161f38] border border-white/10" />
        </div>
        <label className="flex items-center gap-2 text-xs opacity-80">
          <input type="checkbox" checked={hasRealPhoto} onChange={e => setHasRealPhoto(e.target.checked)} />
          Только реальные фото
        </label>
        <div className="flex flex-wrap items-center gap-2">
          <span className="text-xs opacity-70">Узоры:</span>
          {TAGS.map(tag => {
            const checked = selectedTags.includes(tag)
            return (
              <label key={tag} className={`text-xs px-2 py-1 rounded border cursor-pointer ${checked ? 'bg-blue-500/20 border-blue-400/50' : 'bg-[#161f38] border-white/10'}`}>
                <input type="checkbox" className="mr-1" checked={checked} onChange={e => {
                  setSelectedTags(prev => {
                    if (e.target.checked) return [...prev, tag]
                    return prev.filter(x => x !== tag)
                  })
                }} />
                {tag}
              </label>
            )
          })}
        </div>
      </div>
      {/* Carousel Container */}
      <div className="relative">
        {/* Navigation Buttons */}
        <button 
          onClick={() => {
            const container = document.getElementById('skins-carousel');
            container.scrollBy({ left: -300, behavior: 'smooth' });
          }}
          className="absolute left-0 top-1/2 -translate-y-1/2 z-10 bg-blue-600 hover:bg-blue-700 text-white p-2 rounded-full shadow-lg transition-colors"
          style={{ marginLeft: '-20px' }}
        >
