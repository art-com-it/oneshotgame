function Store() {
  const [query, setQuery] = React.useState('')
  const [type, setType] = React.useState('')
  const { addItem } = useCart()
  const { formatPrice } = useLang()
  const products = DATA.products
  const filtered = products.filter(p => (p.name.toLowerCase().includes(query.toLowerCase())) && (!type || p.type === type))

  const listRef = React.useRef(null)
  // Автопрокрутка: старт при видимости карусели, стоп при скрытии
  const autoTimerRef = React.useRef(null)
  const scrollStep = () => {
    const el = listRef.current
    if (!el) return
    const first = el.firstElementChild
    const step = first ? first.getBoundingClientRect().width + 24 : 320
    // если почти конец — возвращаемся в начало, иначе крутим дальше
    const nearEnd = el.scrollLeft + el.clientWidth + step >= el.scrollWidth - 4
    if (nearEnd) {
      el.scrollTo({ left: 0, behavior: 'smooth' })
    } else {
      el.scrollBy({ left: step, behavior: 'smooth' })
    }
  }
  const startAuto = () => {
    if (autoTimerRef.current) return
    autoTimerRef.current = setInterval(scrollStep, 2500)
  }
  const stopAuto = () => {
    if (autoTimerRef.current) {
      clearInterval(autoTimerRef.current)
      autoTimerRef.current = null
    }
  }
  React.useEffect(() => {
    const el = listRef.current
    if (!el) return
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            startAuto()
          } else {
            stopAuto()
          }
        })
      },
      { root: null, threshold: 0.5 }
    )
    observer.observe(el)
    const onEnter = () => stopAuto()
    const onLeave = () => startAuto()
    el.addEventListener('mouseenter', onEnter)
    el.addEventListener('mouseleave', onLeave)
    return () => {
      observer.disconnect()
      el.removeEventListener('mouseenter', onEnter)
      el.removeEventListener('mouseleave', onLeave)
      stopAuto()
    }
  }, [])

  const scrollByItems = (dir) => {
    const el = listRef.current
    if (!el) return
    const first = el.firstElementChild
    const step = first ? first.getBoundingClientRect().width + 24 : 320
    el.scrollBy({ left: dir * step, behavior: 'smooth' })
  }

  return (
    <section className="space-y-6">
      <h2 className="text-2xl font-bold">Каталог</h2>
      <div className="flex gap-3">
        <input value={query} onChange={e => setQuery(e.target.value)} placeholder="Поиск" className="px-3 py-2 rounded bg-[#0D1A2F] border border-white/10 w-64" />
      </div>
      {filtered.length > 0 ? (
        <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          {filtered.map(p => (
            <NavLink to={`/product/${p.id}`} key={p.id} className="flex flex-col p-4 rounded-lg border border-white/10 bg-[#0D1A2F] hover:border-blue-400/50 transition">
              <div className="h-36 rounded-lg bg-[#161f38] overflow-hidden">
                <LazyImage 
              src={p.image || '/vite.svg'} 
              alt={p.name} 
              className="w-full h-full object-cover" 
            />
              </div>
              <h3 className="mt-3 font-semibold">{p.name}</h3>
              <p className="text-white/60 text-sm">Цена: {formatPrice(p.price)}</p>
              <button onClick={(e) => { e.preventDefault(); e.stopPropagation(); addItem(p, 1) }} className="mt-auto px-3 py-2 rounded-md bg-[#161f38] hover:bg-[#7e2aa8]">В корзину</button>
            </NavLink>
          ))}
        </div>
      ) : (
        <div className="text-white/60">Ничего не найдено</div>
      )}
    </section>
  )
}

