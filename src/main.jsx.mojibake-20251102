          {product.category === 'game' && (
            <div className="mt-6">
              <h3 className="text-lg font-semibold">Р В РЎСӣР В Р’ВөР РҺРІРӮВҰР В Р вҖҰР В РЎвҖҳР РҺРІРӮРҺР В Р’ВөР РҺР С“Р В РЎвҖқР В РЎвҖҳР В Р’Вө Р РҺРІРӮВҰР В Р’В°Р РҺР вҖҡР В Р’В°Р В РЎвҖқР РҺРІРӮСҷР В Р’ВөР РҺР вҖҡР В РЎвҖҳР РҺР С“Р РҺРІРӮСҷР В РЎвҖҳР В РЎвҖқР В РЎвҖҳ</h3>
              <ul className="mt-2 text-white/70 text-sm space-y-1">
                <li>Р В Р’В Р В Р’В°Р В Р’В·Р РҺР вҖҡР В Р’В°Р В Р’ВұР В РЎвҖўР РҺРІРӮСҷР РҺРІРӮРҺР В РЎвҖҳР В РЎвҖқ: {product.specs?.developer || 'Р РҶР вҖҡРІРӮСң'}</li>
                <li>Р В РІРӮСҡР В РЎвҖўР В РўвҖҳ Р В Р вҖ Р РҺРІРӮв„–Р В РЎвҖ”Р РҺРЎвҖңР РҺР С“Р В РЎвҖқР В Р’В°: {product.specs?.release || 'Р РҶР вҖҡРІРӮСң'}</li>
                <li>Р В РЎСҹР В Р’В»Р В Р’В°Р РҺРІРӮСҷР РҺРІРӮСӣР В РЎвҖўР РҺР вҖҡР В РЎпҝҪР В Р’В°: {product.specs?.platform || 'Р РҶР вҖҡРІРӮСң'}</li>
                <li>Р В РЎСҷР В РЎвҖҳР В Р вҖҰР В РЎвҖҳР В РЎпҝҪР В Р’В°Р В Р’В»Р РҺР РүР В Р вҖҰР РҺРІРӮв„–Р В Р’Вө Р РҺРІРӮСҷР РҺР вҖҡР В Р’ВөР В Р’ВұР В РЎвҖўР В Р вҖ Р В Р’В°Р В Р вҖҰР В РЎвҖҳР РҺР РҸ: {product.specs?.min || 'Р РҶР вҖҡРІРӮСң'}</li>
              </ul>
