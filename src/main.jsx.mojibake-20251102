// Р В РІРӮСҡР В Р’В»Р В Р’В°Р В Р вҖ Р В Р вҖҰР В Р’В°Р РҺР РҸ Р РҺР С“Р РҺРІРӮСҷР РҺР вҖҡР В Р’В°Р В Р вҖҰР В РЎвҖҳР РҺРІРӮВ Р В Р’В°
function Home() {
  const { formatPrice } = useLang()
  const { cmsContent } = useCMS()
  const [version, setVersion] = React.useState(0)
  
  React.useEffect(() => {
    const onProductsLoaded = () => setVersion(v => v + 1)
    window.addEventListener('products-loaded', onProductsLoaded)
    return () => window.removeEventListener('products-loaded', onProductsLoaded)
  }, [])

  const [remaining, setRemaining] = React.useState('')
  const endsAtRef = React.useRef(Date.now() + 24 * 60 * 60 * 1000) // Р В Р’В°Р В РЎвҖқР РҺРІРӮВ Р В РЎвҖҳР РҺР РҸ 24 Р РҺРІРӮРҺР В Р’В°Р РҺР С“Р В Р’В°
  React.useEffect(() => {
    const update = () => {
      const diff = endsAtRef.current - Date.now()
      if (diff <= 0) { setRemaining('00:00:00'); return }
      const h = Math.floor(diff / 3600000)
      const m = Math.floor((diff % 3600000) / 60000)
      const s = Math.floor((diff % 60000) / 1000)
      setRemaining(`${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`)
    }
    update()
    const t = setInterval(update, 1000)
    return () => clearInterval(t)
  }, [])

  const { addItem } = useCart()
  const addToCart = (product) => {
    const qtyStr = window.prompt('Р В РІРӮв„ўР РҺРІРӮв„–Р В Р’ВұР В Р’ВөР РҺР вҖҡР В РЎвҖҳР РҺРІРӮСҷР В Р’Вө Р В РЎвҖқР В РЎвҖўР В Р’В»Р В РЎвҖҳР РҺРІРӮРҺР В Р’ВөР РҺР С“Р РҺРІРӮСҷР В Р вҖ Р В РЎвҖў', '1')
    const qty = parseInt(qtyStr || '0', 10)
    if (!Number.isNaN(qty) && qty > 0) {
      addItem(product, qty)
    }
  }

  // Р В РЎСҹР РҺР вҖҡР В РЎвҖўР В РЎпҝҪР В РЎвҖў-Р РҺР С“Р В Р’В»Р В Р’В°Р В РІвҖһвҖ“Р В РўвҖҳР В Р’ВөР РҺР вҖҡ Р В Р вҖҰР В Р’В° Р В РЎвҖ“Р В Р’В»Р В Р’В°Р В Р вҖ Р В Р вҖҰР В РЎвҖўР В РІвҖһвҖ“: Р В Р’В°Р В Р вҖ Р РҺРІРӮСҷР В РЎвҖўР В РЎвҖ”Р РҺР вҖҡР В РЎвҖўР В РЎвҖқР РҺР вҖҡР РҺРЎвҖңР РҺРІРӮСҷР В РЎвҖқР В Р’В° Р В Р’ВұР В Р’ВөР В Р’В· Р РҺР вҖҡР РҺРЎвҖңР РҺРІРӮРҺР В Р вҖҰР РҺРІРӮв„–Р РҺРІРӮВҰ Р В РЎвҖқР В РЎвҖўР В Р вҖҰР РҺРІРӮСҷР РҺР вҖҡР В РЎвҖўР В Р’В»Р В РЎвҖўР В Р вҖ 
  const promoRef = React.useRef(null)
  const promoTimerRef = React.useRef(null)
  const promoStep = () => {
    const el = promoRef.current
    if (!el) return
    const first = el.firstElementChild
    const step = first ? first.getBoundingClientRect().width + 24 : 320
    const nearEnd = el.scrollLeft + el.clientWidth + step >= el.scrollWidth - 4
    if (nearEnd) {
      el.scrollTo({ left: 0, behavior: 'smooth' })
    } else {
      el.scrollBy({ left: step, behavior: 'smooth' })
    }
  }
  const startPromo = () => { if (!promoTimerRef.current) promoTimerRef.current = setInterval(promoStep, 2500) }
  const stopPromo = () => { if (promoTimerRef.current) { clearInterval(promoTimerRef.current); promoTimerRef.current = null } }
  React.useEffect(() => {
    const el = promoRef.current
    if (!el) return
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => { entry.isIntersecting ? startPromo() : stopPromo() })
    }, { root: null, threshold: 0.1 })
    observer.observe(el)
    const onEnter = () => stopPromo()
    const onLeave = () => startPromo()
    el.addEventListener('mouseenter', onEnter)
    el.addEventListener('mouseleave', onLeave)
    startPromo()
    return () => { observer.disconnect(); el.removeEventListener('mouseenter', onEnter); el.removeEventListener('mouseleave', onLeave); stopPromo() }
  }, [])

  const promoItems = React.useMemo(() => {
    const items = DATA.products.filter(p => {
      const src = p.introImage || p.image
      return src && !String(src).includes('/images/logo/logo.png')
    })
    const arr = [...items]
    for (let i = arr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1))
      ;[arr[i], arr[j]] = [arr[j], arr[i]]
    }
    return arr.slice(0, 10).map(p => ({ product: p, src: p.introImage || p.image, to: `/product/${p.id}` }))
  }, [version])
  
  // Р В Р’В Р В Р’В°Р В Р вҖҰР В РўвҖҳР В РЎвҖўР В РЎпҝҪР В РЎвҖҳР В Р’В·Р В Р’В°Р РҺРІРӮВ Р В РЎвҖҳР РҺР РҸ Р В РЎвҖҳР В РЎвҖ“Р РҺР вҖҡ Р В Р вҖҰР В Р’В° Р В РЎвҖ“Р В Р’В»Р В Р’В°Р В Р вҖ Р В Р вҖҰР В РЎвҖўР В РІвҖһвҖ“: Р В РўвҖҳР В Р вҖ Р В Р’Вө Р РҺР С“Р РҺРІРӮСҷР РҺР вҖҡР В РЎвҖўР В РЎвҖқР В РЎвҖҳ, Р РҺР вҖҡР В Р’В°Р В Р’В·Р В Р вҖҰР РҺРІРӮв„–Р В Р’Вө Р В РЎвҖ”Р РҺР вҖҡР В РЎвҖҳ Р В РЎвҖқР В Р’В°Р В Р’В¶Р В РўвҖҳР В РЎвҖўР В РЎпҝҪ Р В РЎвҖўР В Р’ВұР В Р вҖҰР В РЎвҖўР В Р вҖ Р В Р’В»Р В Р’ВөР В Р вҖҰР В РЎвҖҳР В РЎвҖҳ
  const gamesShuffled = React.useMemo(() => {
    const list = DATA.products.filter(p => p.category === 'game')
    const arr = [...list]
    for (let i = arr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1))
      ;[arr[i], arr[j]] = [arr[j], arr[i]]
    }
    return arr
  }, [version])
  const gamesRow1 = React.useMemo(() => gamesShuffled.slice(0, 6), [gamesShuffled])
  const gamesRow2 = React.useMemo(() => gamesShuffled.slice(6, 12), [gamesShuffled])

  const scrollToRoulette = React.useCallback(() => {
    const el = document.getElementById('roulette-anchor')
    if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' })
  }, [])
  
  return (
    <section className="space-y-8 p-4 sm:p-6">
      {/* Р В РІРӮСҡР В Р’В»Р В Р’В°Р В Р вҖ Р В Р вҖҰР РҺРІРӮв„–Р В РІвҖһвҖ“ Р В Р’ВұР В Р’В°Р В Р вҖҰР В Р вҖҰР В Р’ВөР РҺР вҖҡ - Hero Section */}
      <div className="relative overflow-hidden rounded-3xl bg-gradient-to-br from-[#0a0f1c] via-[#1a1f3a] to-[#2d1b69] min-h-[500px] flex items-center">
        {/* Р В Р’ВӨР В РЎвҖўР В Р вҖҰР В РЎвҖўР В Р вҖ Р РҺРІРӮв„–Р В Р’Вө Р РҺР РҠР РҺРІРӮСӣР РҺРІРӮСӣР В Р’ВөР В РЎвҖқР РҺРІРӮСҷР РҺРІРӮв„– */}
        <div className="absolute inset-0">
          {/* Р В РЎСҷР В РЎвҖўР В Р вҖҰР РҺРІРӮСҷР В Р’В°Р В Р’В¶ Р В РЎвҖҳР В Р’В·Р В РЎвҖўР В Р’ВұР РҺР вҖҡР В Р’В°Р В Р’В¶Р В Р’ВөР В Р вҖҰР В РЎвҖҳР В РІвҖһвҖ“ Р В РЎвҖҳР В РЎвҖ“Р РҺР вҖҡ/Р РҺР С“Р В РЎвҖқР В РЎвҖҳР В Р вҖҰР В РЎвҖўР В Р вҖ : Р В РўвҖҳР В РЎвҖҳР В Р вҖҰР В Р’В°Р В РЎпҝҪР В РЎвҖҳР РҺРІРӮРҺР В Р вҖҰР В Р’В°Р РҺР РҸ Р РҺР С“Р В Р’ВөР РҺРІРӮСҷР В РЎвҖқР В Р’В° Р В РЎвҖҳР В Р’В· Р В РЎвҖқР В Р вҖ Р В Р’В°Р В РўвҖҳР РҺР вҖҡР В Р’В°Р РҺРІРӮСҷР В РЎвҖўР В Р вҖ  */}
          <div className="absolute inset-0 pointer-events-none">
            <div className="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent"></div>
            <div className="grid grid-cols-5 gap-2 w-full h-full p-4 opacity-20" style={{ gridAutoRows: '100px' }}>
              {DATA.products.slice(0, 25).map((p) => (
                <div key={p.id} className="relative rounded-lg overflow-hidden" style={{ aspectRatio: '1 / 1' }}>
                  <LazyImage src={p.introImage || p.image} alt={p.name} className="w-full h-full object-cover" />
                </div>
              ))}
            </div>
          </div>
          <div className="absolute top-0 left-0 w-96 h-96 bg-blue-500/20 rounded-full blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
          <div className="absolute bottom-0 right-0 w-96 h-96 bg-purple-500/20 rounded-full blur-3xl translate-x-1/2 translate-y-1/2"></div>
          <div className="absolute top-1/2 left-1/2 w-64 h-64 bg-cyan-400/10 rounded-full blur-2xl -translate-x-1/2 -translate-y-1/2"></div>
        </div>
        
        {/* Р В РЎв„ўР В РЎвҖўР В Р вҖҰР РҺРІРӮСҷР В Р’ВөР В Р вҖҰР РҺРІРӮСҷ Р В Р’ВұР В Р’В°Р В Р вҖҰР В Р вҖҰР В Р’ВөР РҺР вҖҡР В Р’В° */}
        <div className="relative z-10 w-full px-8 py-12">
          <div className="max-w-4xl mx-auto text-center">
            <div className="inline-flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-blue-500/20 to-purple-500/20 rounded-full border border-blue-400/30 mb-6">
              <span className="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
              <span className="text-sm text-blue-300 font-medium">Р В РЎвҖҷР В РЎвҖқР РҺРІРӮВ Р В РЎвҖҳР РҺР РҸ Р В Р’В·Р В Р’В°Р В РЎвҖқР В Р’В°Р В Р вҖҰР РҺРІРӮРҺР В РЎвҖҳР В Р вҖ Р В Р’В°Р В Р’ВөР РҺРІРӮСҷР РҺР С“Р РҺР РҸ Р РҺРІРӮРҺР В Р’ВөР РҺР вҖҡР В Р’ВөР В Р’В· {remaining}</span>
            </div>
            
            <h1 className="text-4xl sm:text-5xl lg:text-6xl font-black bg-gradient-to-r from-white via-blue-100 to-purple-200 bg-clip-text text-transparent mb-6 leading-tight">
              {cmsContent.bannerTitle}
            </h1>
            
            <p className="text-lg sm:text-xl text-white/80 mb-8 max-w-2xl mx-auto leading-relaxed">
              {cmsContent.bannerDescription}
            </p>
            
            <div className="flex flex-col sm:flex-row gap-4 justify-center items-center">
              <NavLink 
                to="/skins" 
                className="group relative px-8 py-4 bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-500 hover:to-purple-500 rounded-xl font-bold text-white transition-all duration-300 transform hover:scale-105 hover:shadow-2xl hover:shadow-blue-500/25 min-w-[200px]"
