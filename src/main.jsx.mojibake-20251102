// Р В Р РӢР РҺРІРӮСҷР РҺР вҖҡР В Р’В°Р В Р вҖҰР В РЎвҖҳР РҺРІРӮВ Р В Р’В° Р РҺРІРӮСҷР В РЎвҖўР В Р вҖ Р В Р’В°Р РҺР вҖҡР В Р’В°
function Product() {
  const { id } = useParams()
  const { addItem } = useCart()
  const { formatPrice } = useLang()
  const [version, setVersion] = React.useState(0)
  
  React.useEffect(() => {
    const onProductsLoaded = () => setVersion(v => v + 1)
    window.addEventListener('products-loaded', onProductsLoaded)
    return () => window.removeEventListener('products-loaded', onProductsLoaded)
  }, [])
  
  const product = React.useMemo(() => {
    const byId = DATA.products.find(p => p.id === id)
    if (byId) return byId
    return DATA.products.find(p => String(p.id) === String(id)) || null
  }, [id, version])

  const images = React.useMemo(() => {
    if (!product) return ['/vite.svg','/vite.svg','/vite.svg']
    const base = Array.isArray(product.images) ? product.images.filter(Boolean) : []
    if (base.length === 0 && product.image) base.push(product.image)
    const fallback = '/vite.svg'
    while (base.length < 3) base.push(fallback)
    return base.slice(0, 10)
  }, [product])
  
  const [idx, setIdx] = React.useState(0)
  const go = (d) => setIdx(i => (i + d + images.length) % images.length)

  const recommendations = React.useMemo(() => {
    const list = DATA.products.filter(p => p.id !== (product?.id || ''))
    const arr = [...list]
    for (let i = arr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1))
      ;[arr[i], arr[j]] = [arr[j], arr[i]]
    }
    return arr.slice(0, 4)
  }, [product])

  const [sellStatus, setSellStatus] = React.useState('')
  const getRarityClasses = (rarity) => {
    switch (String(rarity || '').toLowerCase()) {
      case 'РІпҝҪвҖҰ covert':
      case 'covert':
        return 'bg-red-600 text-white'
      case 'classified':
        return 'bg-pink-600 text-white'
      case 'restricted':
        return 'bg-purple-600 text-white'
      case 'mil-spec':
        return 'bg-blue-600 text-white'
      case 'consumer grade':
        return 'bg-gray-600 text-white'
      case 'rare':
        return 'bg-green-600 text-white'
      case 'unusual':
        return 'bg-fuchsia-600 text-white'
      case 'immortal':
        return 'bg-amber-500 text-black'
      case 'souvenir':
        return 'bg-yellow-400 text-black'
      default:
        return 'bg-[#0D1A2F] text-white/70 border border-white/10'
    }
  }
  const sellSkin = () => {
    try {
      const isAuth = localStorage.getItem('profile-auth') === '1'
      if (!isAuth) {
        window.dispatchEvent(new Event('open-login'))
        return
      }
      if (!product || product.category !== 'skin') return
      const credit = Math.round(product.price * 0.7 * 100) / 100
      const prev = parseFloat(localStorage.getItem('wallet-usd') || '0')
      const next = Math.round((prev + credit) * 100) / 100
      localStorage.setItem('wallet-usd', String(next))
      let hist = []
      try { hist = JSON.parse(localStorage.getItem('wallet-history') || '[]') } catch { hist = [] }
      const item = { id: `SELL-${Date.now()}`, type: 'sell', amountUsd: credit, name: product.name, ts: Date.now() }
      localStorage.setItem('wallet-history', JSON.stringify([item, ...hist]))
      window.dispatchEvent(new Event('wallet-updated'))
      setSellStatus('sold')
    } catch (e) {
      console.error('sellSkin error', e)
    }
  }

  if (!product) {
    return (
      <section className="space-y-6">
        <h2 className="text-2xl font-bold">Р В РЎСӣР В РЎвҖўР В Р вҖ Р В Р’В°Р РҺР вҖҡ Р В Р вҖҰР В Р’Вө Р В Р вҖҰР В Р’В°Р В РІвҖһвҖ“Р В РўвҖҳР В Р’ВөР В Р вҖҰ</h2>
        <div className="text-white/60">Р В РЎСҹР В РЎвҖўР РҺРІРӮВҰР В РЎвҖўР В Р’В¶Р В Р’Вө, Р РҺРІРӮСҷР В Р’В°Р В РЎвҖқР В РЎвҖўР В РЎвҖ“Р В РЎвҖў Р РҺРІРӮСҷР В РЎвҖўР В Р вҖ Р В Р’В°Р РҺР вҖҡР В Р’В° Р В Р вҖҰР В Р’ВөР РҺРІРӮСҷ Р В Р вҖ  Р В РЎвҖқР В Р’В°Р РҺРІРӮСҷР В Р’В°Р В Р’В»Р В РЎвҖўР В РЎвҖ“Р В Р’Вө.</div>
      </section>
    )
  }

  return (
    <section className="space-y-6">
      <h2 className="text-2xl font-bold">{product.name}</h2>
      <div className="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">
        <div className="p-4 rounded-lg border border-white/10 bg-[#0D1A2F]">
          <div className="h-72 rounded-lg bg-[#161f38] overflow-hidden">
            <div className="relative w-full h-full">
              <LazyImage 
                src={images[idx]} 
                alt={`${product.name}-${idx+1}`} 
                className="w-full h-full object-cover transition-opacity duration-300" 
              />
              <button aria-label="prev" onClick={() => go(-1)} className="absolute left-2 top-1/2 -translate-y-1/2 px-2 py-1 rounded bg-[#0D1A2F] border border-white/10">Р РҶР вҖҡРІвҖһвҖ“</button>
              <button aria-label="next" onClick={() => go(1)} className="absolute right-2 top-1/2 -translate-y-1/2 px-2 py-1 rounded bg-[#0D1A2F] border border-white/10">Р РҶР вҖҡРЎвҖқ</button>
              <div className="absolute bottom-2 left-0 right-0 flex justify-center gap-2">
                {images.map((_, i) => (
                  <button key={i} onClick={() => setIdx(i)} aria-label={`go-${i}`} className={`h-2 w-2 rounded-full ${i===idx?'bg-[#4A90E2]':'bg-white/30'}`}></button>
                ))}
              </div>
            </div>
          </div>
        </div>
        <div className="p-4 rounded-lg border border-white/10 bg-[#0D1A2F] lg:col-span-2 flex flex-col">
          <div className="text-white/80">Р В Р’ВҰР В Р’ВөР В Р вҖҰР В Р’В°: {formatPrice(product.price)}</div>
          <div className="mt-2 text-white/60 text-sm">Р В РЎв„ўР В Р’В°Р РҺРІРӮСҷР В Р’ВөР В РЎвҖ“Р В РЎвҖўР РҺР вҖҡР В РЎвҖҳР РҺР РҸ: {product.category || 'Р РҶР вҖҡРІРӮСң'}{product.type ? ` Р РҶР вҖҡРЎСӣ ${product.type}` : ''}</div>
          {product.category === 'skin' && product.rarity && (
            <div className="mt-2">
              <span className={`inline-block px-2 py-0.5 rounded text-xs ${getRarityClasses(product.rarity)}`}>
                {product.rarity}
              </span>
            </div>
          )}
          <div className="mt-4 flex items-center gap-2">
            <button onClick={() => addItem(product, 1)} className="px-4 py-2 rounded-md bg-[#161f38] hover:bg-[#7e2aa8]">Р В РІРӮв„ў Р В РЎвҖқР В РЎвҖўР РҺР вҖҡР В Р’В·Р В РЎвҖҳР В Р вҖҰР РҺРЎвҖң</button>
            {product.category === 'skin' && (
              <button onClick={sellSkin} className="px-4 py-2 rounded-md bg-[#4A90E2] hover:bg-[#7e2aa8]">Р В РЎСҹР РҺР вҖҡР В РЎвҖўР В РўвҖҳР В Р’В°Р РҺРІРӮСҷР РҺР Рү Р РҺР С“Р В РЎвҖқР В РЎвҖҳР В Р вҖҰ (70%)</button>
            )}
            {sellStatus === 'sold' && (
              <div className="ml-2 text-xs text-green-400">Р В РІРӮвҖқР В Р’В°Р РҺРІРӮРҺР В РЎвҖҳР РҺР С“Р В Р’В»Р В Р’ВөР В Р вҖҰР В РЎвҖў: {formatPrice(product.price * 0.7)}</div>
            )}
          </div>
          {/* Р В РЎвҖәР В РЎвҖ”Р В РЎвҖҳР РҺР С“Р В Р’В°Р В Р вҖҰР В РЎвҖҳР В Р’Вө Р В РЎвҖҳР В РЎвҖ“Р РҺР вҖҡР РҺРІРӮв„– */}
          <div className="mt-6">
            <h3 className="text-lg font-semibold">Р В РЎвҖәР В РЎвҖ”Р В РЎвҖҳР РҺР С“Р В Р’В°Р В Р вҖҰР В РЎвҖҳР В Р’Вө</h3>
