      </div>

      {/* Р В Р РӢ Р РҺР РҠР РҺРІРӮСҷР В РЎвҖҳР В РЎпҝҪ Р В Р’ВөР РҺРІРӮВ°Р В Р’Вө Р В РЎвҖ”Р В РЎвҖўР В РЎвҖқР РҺРЎвҖңР В РЎвҖ”Р В Р’В°Р РҺР вҖ№Р РҺРІРӮСҷ */}
      {recommendations.length > 0 && (
        <div className="space-y-3">
          <h3 className="text-xl font-bold">Р В Р РӢ Р РҺР РҠР РҺРІРӮСҷР В РЎвҖҳР В РЎпҝҪ Р В Р’ВөР РҺРІРӮВ°Р В Р’Вө Р В РЎвҖ”Р В РЎвҖўР В РЎвҖқР РҺРЎвҖңР В РЎвҖ”Р В Р’В°Р РҺР вҖ№Р РҺРІРӮСҷ</h3>
          <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
            {recommendations.map(p => (
              <div key={p.id} className="bg-[#161f38] rounded-lg overflow-hidden border border-white/10 hover:border-blue-500/50 transition-colors">
