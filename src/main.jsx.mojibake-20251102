// Р В РЎв„ўР В Р’В°Р РҺР вҖҡР РҺРІРӮСҷР В РЎвҖўР РҺРІРӮРҺР В РЎвҖқР В Р’В° Р В РЎвҖҳР В РЎвҖ“Р РҺР вҖҡР РҺРІРӮв„–
function GameCard({ product, addItem, fullSlider = false }) {
  const { formatPrice } = useLang()
  const previews = React.useMemo(() => getPreviewImages(product), [product])
  const [idx, setIdx] = React.useState(0)
  const prev = () => setIdx(i => (i - 1 + previews.length) % previews.length)
  const next = () => setIdx(i => (i + 1) % previews.length)
  const navigate = useNavigate()

  return (
    <div onClick={() => navigate(`/product/${product.id}`)} className="group relative flex flex-col p-4 rounded-lg border border-white/10 bg-[#0D1A2F] hover:border-blue-400/50 transition cursor-pointer">
      <div className={`${fullSlider ? 'h-60 sm:h-64' : 'h-36'} rounded-lg bg-[#161f38] overflow-hidden relative`}>
        {fullSlider ? (
          <>
            <LazyImage 
              src={previews[idx]} 
              alt={`${product.name}-preview-${idx+1}`} 
              className="w-full h-full object-cover" 
            />
            <button onClick={(e) => { e.stopPropagation(); prev() }} className="absolute left-2 top-1/2 -translate-y-1/2 px-2 py-1 rounded bg-[#0D1A2F] border border-white/10">Р РҶР вҖҡРІвҖһвҖ“</button>
            <button onClick={(e) => { e.stopPropagation(); next() }} className="absolute right-2 top-1/2 -translate-y-1/2 px-2 py-1 rounded bg-[#0D1A2F] border border-white/10">Р РҶР вҖҡРЎвҖқ</button>
            <div className="absolute bottom-2 left-0 right-0 flex justify-center gap-2">
              {previews.map((_, i) => (
                <button key={i} onClick={(e) => { e.stopPropagation(); setIdx(i) }} aria-label={`go-${i}`} className={`h-2 w-2 rounded-full ${i===idx?'bg-[#4A90E2]':'bg-white/30'}`}></button>
              ))}
            </div>
          </>
        ) : (
          <>
            <LazyImage 
              src={product.image || '/vite.svg'} 
              alt={product.name} 
              className="w-full h-full object-cover" 
            />
            <div className="absolute bottom-2 left-2 right-2">
              <div className="flex items-center gap-2">
                <button onClick={(e) => { e.stopPropagation(); prev() }} className="px-2 py-1 rounded bg-[#161f38] hover:bg-[#7e2aa8]">&lsaquo;</button>
                <div className="flex-1 h-14 rounded border border-white/10 overflow-hidden bg-[#0D1A2F]">
                  <img src={previews[idx]} alt={`${product.name}-preview`} className="w-full h-full object-cover" loading="lazy" decoding="async" />
                </div>
                <button onClick={(e) => { e.stopPropagation(); next() }} className="px-2 py-1 rounded bg-[#161f38] hover:bg-[#7e2aa8]">&rsaquo;</button>
              </div>
            </div>
          </>
        )}
      </div>
      <h3 className="mt-3 font-semibold">{product.name}</h3>
      <p className="text-white/60 text-sm">{formatPrice(product.price)}</p>
      <div className="mt-auto flex items-center gap-2">
        <button onClick={(e) => { e.stopPropagation(); addItem(product, 1) }} className="px-3 py-2 rounded-md bg-[#161f38] hover:bg-[#7e2aa8]">Р В РІРӮв„ў Р В РЎвҖқР В РЎвҖўР РҺР вҖҡР В Р’В·Р В РЎвҖҳР В Р вҖҰР РҺРЎвҖң</button>
      </div>
    </div>
  )
}

