function LangProvider({ children }) {
  const [lang, setLang] = React.useState(() => localStorage.getItem('lang') || 'ru')
  React.useEffect(() => { localStorage.setItem('lang', lang) }, [lang])
  const RATE = 90
  const currency = lang === 'ru' ? 'RUB' : 'USD'
  const formatPrice = (amountUsd) => {
    try {
      if (lang === 'ru') return new Intl.NumberFormat('ru-RU', { style: 'currency', currency: 'RUB' }).format(amountUsd * RATE)
      return new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(amountUsd)
    } catch {
      return lang === 'ru' ? `${Math.round(amountUsd * RATE)} Р РҶРІРӮСҷР вҖҰ` : `$${amountUsd.toFixed(2)}`
    }
  }
  const toAmountInCurrency = (amountUsd) => lang === 'ru' ? amountUsd * RATE : amountUsd
  const DICT = {
    ru: { 'skins.title': 'Р В Р РӢР В РЎвҖқР В РЎвҖҳР В Р вҖҰР РҺРІРӮв„– CS2' },
    en: { 'skins.title': 'CS2 Skins' }
  }
  const t = (key) => (DICT[lang] && DICT[lang][key]) || key
  const value = { lang, setLang, currency, rate: RATE, formatPrice, toAmountInCurrency, t }
  return <LangContext.Provider value={value}>{children}</LangContext.Provider>
}

function useLang() { 
  const ctx = React.useContext(LangContext); 
  if (!ctx) throw new Error('useLang must be used within LangProvider'); 
  return ctx; 
}

// LazyImage Р В РЎвҖқР В РЎвҖўР В РЎпҝҪР В РЎвҖ”Р В РЎвҖўР В Р вҖҰР В Р’ВөР В Р вҖҰР РҺРІРӮСҷ Р В РўвҖҳР В Р’В»Р РҺР РҸ Р В РЎвҖўР В РЎвҖ”Р РҺРІРӮСҷР В РЎвҖҳР В РЎпҝҪР В РЎвҖҳР В Р’В·Р В РЎвҖҳР РҺР вҖҡР В РЎвҖўР В Р вҖ Р В Р’В°Р В Р вҖҰР В Р вҖҰР В РЎвҖўР В РІвҖһвҖ“ Р В Р’В·Р В Р’В°Р В РЎвҖ“Р РҺР вҖҡР РҺРЎвҖңР В Р’В·Р В РЎвҖқР В РЎвҖҳ Р В РЎвҖҳР В Р’В·Р В РЎвҖўР В Р’ВұР РҺР вҖҡР В Р’В°Р В Р’В¶Р В Р’ВөР В Р вҖҰР В РЎвҖҳР В РІвҖһвҖ“
 function LazyImage({ src, alt, className, fallback = '/vite.svg', ...props }) {
  const [imageSrc, setImageSrc] = React.useState(fallback)
  const [isLoading, setIsLoading] = React.useState(true)
  const [hasError, setHasError] = React.useState(false)
  const imgRef = React.useRef(null)

  React.useEffect(() => {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const img = new Image()
            img.onload = () => {
              setImageSrc(src)
              setIsLoading(false)
              setHasError(false)
            }
            img.onerror = () => {
              setImageSrc(fallback)
              setIsLoading(false)
              setHasError(true)
            }
            img.src = src
            observer.unobserve(entry.target)
          }
        })
      },
      { threshold: 0.1, rootMargin: '50px' }
    )

    if (imgRef.current) {
      observer.observe(imgRef.current)
    }

    return () => observer.disconnect()
  }, [src, fallback])

  return (
    <div ref={imgRef} className={`relative ${className || ''}`}>
      <img
        src={imageSrc}
        alt={alt}
        className={`transition-opacity duration-300 ${isLoading ? 'opacity-50' : 'opacity-100'} ${className || ''}`}
        loading="lazy"
        decoding="async"
        {...props}
      />
      {isLoading && (
        <div className="absolute inset-0 flex items-center justify-center bg-[#161f38] animate-pulse">
          <div className="w-8 h-8 border-2 border-white/20 border-t-white/60 rounded-full animate-spin"></div>
        </div>
      )}
    </div>
  )
}

