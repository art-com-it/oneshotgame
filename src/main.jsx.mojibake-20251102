  const { items, totalPrice, clear } = useCart()
  const { formatPrice, currency, toAmountInCurrency } = useLang()
  const [acquirerConnected, setAcquirerConnected] = React.useState(() => localStorage.getItem('acquirer') === '1')
  React.useEffect(() => { localStorage.setItem('acquirer', acquirerConnected ? '1' : '0') }, [acquirerConnected])
  const [orderId] = React.useState(() => `ORD-${Date.now()}`)
  const [status, setStatus] = React.useState('waiting')
  const [email, setEmail] = React.useState('')
  const [emailError, setEmailError] = React.useState('')
  const amountInCurr = toAmountInCurrency(totalPrice)
  const dataStr = `aigame://pay?order=${orderId}&amount=${amountInCurr.toFixed(2)}&currency=${currency}`
  const qrUrl = `https://api.qrserver.com/v1/create-qr-code/?size=220x220&data=${encodeURIComponent(dataStr)}`

  React.useEffect(() => {
    const t = setTimeout(() => setStatus('paid'), 15000)
    return () => clearTimeout(t)
  }, [orderId])

  const validateEmail = (email) => {
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/
    return emailRegex.test(email)
  }

  const handleEmailChange = (e) => {
    const value = e.target.value
    setEmail(value)
    if (value && !validateEmail(value)) {
      setEmailError('Р В РІРӮв„ўР В Р вҖ Р В Р’ВөР В РўвҖҳР В РЎвҖҳР РҺРІРӮСҷР В Р’Вө Р В РЎвҖқР В РЎвҖўР РҺР вҖҡР РҺР вҖҡР В Р’ВөР В РЎвҖқР РҺРІРӮСҷР В Р вҖҰР РҺРІРӮв„–Р В РІвҖһвҖ“ email Р В Р’В°Р В РўвҖҳР РҺР вҖҡР В Р’ВөР РҺР С“')
    } else {
      setEmailError('')
    }
  }

  const markPaid = async () => {
    if (!email || !validateEmail(email)) {
      setEmailError('Р В РІРӮв„ўР В Р вҖ Р В Р’ВөР В РўвҖҳР В РЎвҖҳР РҺРІРӮСҷР В Р’Вө Р В РЎвҖқР В РЎвҖўР РҺР вҖҡР РҺР вҖҡР В Р’ВөР В РЎвҖқР РҺРІРӮСҷР В Р вҖҰР РҺРІРӮв„–Р В РІвҖһвҖ“ email Р В РўвҖҳР В Р’В»Р РҺР РҸ Р В РЎвҖ”Р В РЎвҖўР В Р’В»Р РҺРЎвҖңР РҺРІРӮРҺР В Р’ВөР В Р вҖҰР В РЎвҖҳР РҺР РҸ Р РҺРІРӮРҺР В Р’ВөР В РЎвҖқР В Р’В°')
      return
    }
    setStatus('paid')
    const userName = localStorage.getItem('profile-name') || ''
    const game = items && items.length > 0 ? (items[0].type || 'cs2') : 'cs2'
    const orderData = {
      userEmail: email,
      userName,
      items: (items || []).map(i => ({ name: i.name, price: i.price, quality: i.quality })),
      totalAmount: totalPrice,
      orderId,
      game
    }
    try {
      const res = await sendPurchaseEmail(orderData)
      console.log('Р В Р’В Р В Р’ВөР В Р’В·Р РҺРЎвҖңР В Р’В»Р РҺР РүР РҺРІРӮСҷР В Р’В°Р РҺРІРӮСҷ Р В РЎвҖўР РҺРІРӮСҷР В РЎвҖ”Р РҺР вҖҡР В Р’В°Р В Р вҖ Р В РЎвҖқР В РЎвҖҳ email:', res)
      // Р В РЎвҖәР РҺРІРӮРҺР В РЎвҖҳР РҺРІРӮВ°Р В Р’В°Р В Р’ВөР В РЎпҝҪ Р В РЎвҖқР В РЎвҖўР РҺР вҖҡР В Р’В·Р В РЎвҖҳР В Р вҖҰР РҺРЎвҖң Р В РЎвҖ”Р В РЎвҖўР РҺР С“Р В Р’В»Р В Р’Вө Р РҺРЎвҖңР РҺР С“Р В РЎвҖ”Р В Р’ВөР РҺРІвҖҡВ¬Р В Р вҖҰР В РЎвҖўР В РІвҖһвҖ“ Р В РЎвҖўР В РЎвҖ”Р В Р’В»Р В Р’В°Р РҺРІРӮСҷР РҺРІРӮв„–
      clear()
    } catch (err) {
      console.error('Р В РЎСҡР В Р’Вө Р РҺРЎвҖңР В РўвҖҳР В Р’В°Р В Р’В»Р В РЎвҖўР РҺР С“Р РҺР Рү Р В РЎвҖўР РҺРІРӮСҷР В РЎвҖ”Р РҺР вҖҡР В Р’В°Р В Р вҖ Р В РЎвҖҳР РҺРІРӮСҷР РҺР Рү email:', err)
